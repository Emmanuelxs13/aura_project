{
  "info": {
    "name": "Aura Store API",
    "description": "Coleccion completa de endpoints para la API de Aura Store. Incluye autenticacion, productos, pedidos y administracion.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "headers": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Test\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Iniciar sesion",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "headers": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@aura.co\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Obtener usuario actual",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Productos (Publico)",
      "item": [
        {
          "name": "Listar productos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": ["{{base_url}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Listar por categoria",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?category=iPhone",
              "host": ["{{base_url}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "category", "value": "iPhone" }
              ]
            }
          }
        },
        {
          "name": "Productos destacados",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/featured",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "featured"]
            }
          }
        },
        {
          "name": "Buscar productos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/search?q=iPhone",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "search"],
              "query": [
                { "key": "q", "value": "iPhone" }
              ]
            }
          }
        },
        {
          "name": "Detalle de producto",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/iphone-16-pro",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "iphone-16-pro"]
            }
          }
        },
        {
          "name": "Categorias",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "categories"]
            }
          }
        }
      ]
    },
    {
      "name": "Pedidos (Auth)",
      "item": [
        {
          "name": "Crear pedido",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipping_name\": \"Juan Perez\",\n  \"shipping_email\": \"juan@example.com\",\n  \"shipping_address\": \"Calle 123, Bogota\",\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"quantity\": 2\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Mis pedidos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Detalle pedido",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/orders/1",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "1"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - Dashboard",
      "item": [
        {
          "name": "Dashboard metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "dashboard"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Analytics completos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/analytics",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "analytics"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - Productos CRUD",
      "item": [
        {
          "name": "Listar productos (admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/products",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "products"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/admin/products",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "products"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Apple Watch Ultra 2\",\n  \"slug\": \"apple-watch-ultra-2\",\n  \"category\": \"Accessories\",\n  \"tagline\": \"Aventura sin limites.\",\n  \"description\": \"El reloj mas robusto y capaz de Apple.\",\n  \"price\": 3499000,\n  \"compare_at_price\": 3999000,\n  \"stock\": 15,\n  \"featured\": true,\n  \"colorway\": \"Titanium\",\n  \"specifications\": {\n    \"case\": \"49mm\",\n    \"battery\": \"36h\",\n    \"chip\": \"S9\"\n  }\n}"
            }
          }
        },
        {
          "name": "Obtener producto por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/products/1",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "products", "1"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Actualizar producto",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/api/admin/products/1",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "products", "1"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 4999000,\n  \"stock\": 25\n}"
            }
          }
        },
        {
          "name": "Eliminar producto",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/admin/products/99",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "products", "99"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - Usuarios",
      "item": [
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Cambiar rol de usuario",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/api/admin/users/2/role",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", "2", "role"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"Admin\"\n}"
            }
          }
        },
        {
          "name": "Suspender/activar usuario",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/api/admin/users/2/status",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", "2", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Suspended\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Pedidos",
      "item": [
        {
          "name": "Listar pedidos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "orders"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Filtrar por estado",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/orders?status=Pending",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "orders"],
              "query": [
                { "key": "status", "value": "Pending" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Actualizar estado",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/api/admin/orders/1/status",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "orders", "1", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Processing\"\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
