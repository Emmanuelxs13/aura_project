<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/main.css">
  <script defer src="/js/catalog.js"></script>
</head>
<body>
  <%- include('../shared/header', { active: 'shop' }) %>
  <main class="apple-shell">
    <section class="section-heading" data-reveal>
      <p class="eyebrow">Tienda Aura</p>
      <h1>Catálogo operativo de hardware</h1>
      <p class="subtitle">Explora productos, filtra por categoría y agrega unidades a la bolsa.</p>
      <% if (category) { %>
        <p class="subtitle">Filtro activo: <%= category %></p>
      <% } %>
    </section>

    <section class="shop-toolbar card" data-reveal>
      <form class="shop-toolbar__search" method="get" action="/shop">
          <input id="catalogSearchInput" type="text" name="search" value="<%= search %>" placeholder="Buscar Mac, iPhone, accesorios..." aria-label="Buscar productos">
        <button class="btn-apple" type="submit">Buscar</button>
      </form>
        <div
          id="catalogSuggestions"
          class="shop-toolbar__suggestions"
          data-endpoint="/api/v1/products/search"
          aria-live="polite"
          hidden
        ></div>
      <div class="shop-toolbar__chips">
        <a class="chip" href="/shop">Todo</a>
        <a class="chip" href="/shop?category=Mac">Mac</a>
        <a class="chip" href="/shop?category=iPhone">iPhone</a>
        <a class="chip" href="/shop?category=iPad">iPad</a>
        <a class="chip" href="/shop?category=Audio">Audio</a>
        <a class="chip" href="/shop?category=Displays">Displays</a>
        <a class="chip" href="/shop?category=Accessories">Accessories</a>
      </div>
    </section>

    <section class="shop-summary" data-reveal>
      <p class="subtitle"><strong><%= products.length %></strong> productos disponibles</p>
      <div class="shop-summary__meta">
        <% if (search) { %>
          Resultados para "<%= search %>"
        <% } else { %>
          Colección completa con disponibilidad en tiempo real
        <% } %>
      </div>
    </section>

    <section class="grid grid--cards">
      <% products.forEach((product) => { %>
        <article class="card product-card product-card--<%= product.category.toLowerCase() %>" data-reveal>
          <div class="product-card__media">
            <img loading="lazy" decoding="async" src="<%= product.image || ('/images/products/' + (product.slug || 'placeholder') + '.svg') %>" alt="<%= product.name %>" onerror="this.src='/images/placeholder.svg'" />
          </div>
          <div class="product-card__body">
            <p class="device-card__meta"><%= product.category %> · <%= product.colorway %></p>
            <h2><a href="/product/<%= product.slug %>"><%= product.name %></a></h2>
            <p class="subtitle"><%= product.tagline %></p>
            <p class="font-numeric">$<%= Number(product.price).toLocaleString('es-CO') %> COP</p>
            <form method="post" action="/cart/items" class="product-card__actions">
              <input type="hidden" name="productId" value="<%= product.id %>">
              <input type="hidden" name="quantity" value="1">
              <button class="btn-link" type="submit">Agregar a la bolsa</button>
            </form>
          </div>
        </article>
      <% }) %>
    </section>
  </main>
  <%- include('../shared/footer') %>
</body>
</html>
