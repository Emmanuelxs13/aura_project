<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include('shared/header', { active: 'dashboard' }) %>
  <main class="apple-shell">
    <section class="section-heading">
      <p class="eyebrow">Cuenta</p>
      <h1>Tu historial y estado de compras</h1>
      <p class="subtitle">Vista personalizada para el usuario autenticado y acceso rapido a sus pedidos.</p>
    </section>

    <section class="kpi-grid">
      <article class="card kpi-card"><span>Productos activos</span><strong><%= products.length %></strong></article>
      <article class="card kpi-card"><span>Pedidos realizados</span><strong><%= orders.length %></strong></article>
      <article class="card kpi-card"><span>Ingresos globales</span><strong>$<%= Number(overview.total_revenue || 0).toLocaleString('es-CO') %></strong></article>
    </section>

    <section class="grid grid--cards">
      <% orders.forEach((order) => { %>
        <article class="card device-card">
          <div class="device-card__meta">Pedido #<%= order.id %></div>
          <h2><%= order.status %></h2>
          <p><%= new Date(order.created_at).toLocaleDateString('es-CO') %> · $<%= Number(order.total_amount).toLocaleString('es-CO') %></p>
          <p class="subtitle"><%= order.shipping_name %></p>
        </article>
      <% }) %>
    </section>
  </main>
  <%- include('shared/footer') %>
</body>
</html>
