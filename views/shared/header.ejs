<header class="topbar">
  <div class="apple-shell topbar__inner">
    <a class="brand" href="/">Aura Store</a>
    <nav class="nav">
      <a href="/" class="<%= active === 'home' ? 'is-active' : '' %>">Inicio</a>
      <a href="/shop" class="<%= active === 'shop' ? 'is-active' : '' %>">Tienda</a>
      <a href="/cart" class="<%= active === 'cart' ? 'is-active' : '' %>">Bolsa (<%= cartCount || 0 %>)</a>
      <a href="/dashboard" class="<%= active === 'dashboard' ? 'is-active' : '' %>">Cuenta</a>
      <% if (isAdmin) { %>
        <a href="/admin" class="<%= active === 'admin' ? 'is-active' : '' %>">Admin</a>
        <a href="/analytics" class="<%= active === 'analytics' ? 'is-active' : '' %>">Analítica</a>
      <% } %>
    </nav>
    <div class="topbar__actions">
      <% if (currentUser) { %>
        <span class="topbar__user"><%= currentUser.name %></span>
        <form method="post" action="/logout">
          <button class="btn-link btn-link--small" type="submit">Salir</button>
        </form>
      <% } else { %>
        <a class="btn-link btn-link--small" href="/login">Entrar</a>
      <% } %>
    </div>
  </div>
</header>
