<aside class="admin-sidebar" aria-label="Navegacion administrativa">
  <div class="admin-sidebar__brand">
    <span class="admin-sidebar__badge">Admin</span>
    <strong>Aura Console</strong>
  </div>
  <nav class="admin-sidebar__nav">
    <a
      href="/admin"
      class="admin-sidebar__link <%= active === 'admin' ? 'is-active' : '' %>"
      >Dashboard Global</a
    >
    <a
      href="/admin/users"
      class="admin-sidebar__link <%= active === 'users' ? 'is-active' : '' %>"
      >Gestion de Usuarios</a
    >
    <a
      href="/admin/inventory"
      class="admin-sidebar__link <%= active === 'inventory' ? 'is-active' : '' %>"
      >Control de Inventario (Productos)</a
    >
    <a
      href="/admin/devices"
      class="admin-sidebar__link <%= active === 'devices' ? 'is-active' : '' %>"
      >Activos (Dispositivos)</a
    >
    <a
      href="/admin/support"
      class="admin-sidebar__link <%= active === 'support' ? 'is-active' : '' %>"
      >Mantenimiento y Soporte</a
    >
    <a
      href="/admin/audit"
      class="admin-sidebar__link <%= active === 'audit' ? 'is-active' : '' %>"
      >Registro de Auditoría</a
    >
    <a
      href="/admin/settings"
      class="admin-sidebar__link <%= active === 'settings' ? 'is-active' : '' %>"
      >Configuracion del Sistema</a
    >
  </nav>
  <div class="admin-sidebar__footer">
    <div>
      <p class="admin-sidebar__meta">Sesión</p>
      <p class="admin-sidebar__user">
        <%= currentUser ? currentUser.name : 'Administrador' %>
      </p>
    </div>
    <form method="post" action="/logout">
      <button class="btn-link btn-link--small" type="submit">Salir</button>
    </form>
  </div>
</aside>
