<aside class="admin-sidebar" aria-label="Navegación del centro ejecutivo">
  <div class="admin-sidebar__brand">
    <p class="admin-sidebar__eyebrow">Aura Ops</p>
    <strong>Centro Ejecutivo</strong>
    <p>Modo oscuro premium para administrar catálogo, contenido y marketing.</p>
  </div>

  <nav class="admin-sidebar__menu">
    <div>
      <p class="admin-sidebar__section-label">Estructura</p>
      <a
        href="/admin/dashboard"
        class="admin-sidebar__link <%= active === 'dashboard' ? 'is-active' : '' %>"
        >Inicio</a
      >
      <a
        href="/admin/catalog"
        class="admin-sidebar__link <%= active === 'catalog' ? 'is-active' : '' %>"
        >Catálogo</a
      >
      <a
        href="/admin/cms-landing"
        class="admin-sidebar__link <%= active === 'cms' ? 'is-active' : '' %>"
        >CMS Landing</a
      >
      <a
        href="/admin/marketing"
        class="admin-sidebar__link <%= active === 'marketing' ? 'is-active' : '' %>"
        >Marketing</a
      >
    </div>

    <div class="admin-sidebar__collections">
      <p class="admin-sidebar__section-label">Colecciones</p>
      <a href="/admin/catalog#laptops" class="admin-sidebar__link">Laptops</a>
      <a href="/admin/catalog#smartphones" class="admin-sidebar__link"
        >Smartphones</a
      >
      <a href="/admin/catalog#gaming" class="admin-sidebar__link">Gaming</a>
      <a href="/admin/catalog#accesorios" class="admin-sidebar__link"
        >Accesorios</a
      >
      <a href="/admin/catalog#smarthome" class="admin-sidebar__link"
        >Smart Home</a
      >
    </div>
  </nav>

  <div class="admin-sidebar__footer">
    <div>
      <p class="admin-sidebar__meta">Sesión</p>
      <p class="admin-sidebar__user">
        <%= currentUser ? currentUser.name : 'Administrador' %>
      </p>
    </div>
    <div class="admin-sidebar__footer-actions">
      <a class="admin-btn admin-btn--small admin-btn--ghost" href="/">Tienda</a>
      <a
        class="admin-btn admin-btn--small admin-btn--ghost"
        href="/admin/dashboard"
        >Dashboard</a
      >
      <form method="post" action="/logout">
        <button
          class="admin-btn admin-btn--small admin-btn--ghost"
          type="submit"
        >
          Salir
        </button>
      </form>
    </div>
  </div>
</aside>
