<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/main.css">
  <script defer src="/vendor/chart.umd.min.js"></script>
  <script defer src="/js/admin-charts.js"></script>
  <script defer src="/js/admin-ui.js"></script>
</head>
<body class="admin-app">
  <% const useAdminLayout = Boolean(isAdmin); %>
  <% if (!useAdminLayout) { %>
    <%- include('shared/header', { active: 'admin' }) %>
  <% } %>
  <% const activityItems = overview.recentActivity || [
    { actor: 'Juan Perez', action: 'asigno MacBook Pro', area: 'Ingenieria', when: 'Hace 3 min' },
    { actor: 'Mariana Soto', action: 'actualizo stock iPad', area: 'Inventario', when: 'Hace 12 min' },
    { actor: 'Equipo TI', action: 'cerró incidencia #204', area: 'Soporte', when: 'Hace 45 min' },
    { actor: 'Carlos Vega', action: 'cambio rol a Auditor', area: 'Usuarios', when: 'Hoy 08:10' }
  ]; %>
  <div class="admin-layout">
    <input class="admin-nav-toggle" type="checkbox" id="admin-nav-toggle" aria-label="Abrir menu admin">
    <%- include('shared/admin-sidebar', { active: 'admin' }) %>
    <div class="admin-panel">
      <header class="admin-statusbar">
        <label class="admin-toggle" for="admin-nav-toggle" aria-hidden="true">
          <span></span>
          <span></span>
        </label>
        <div>
          <p class="admin-statusbar__eyebrow">Centro Ejecutivo</p>
          <h1>Control de acceso y activos</h1>
        </div>
        <div class="admin-statusbar__actions">
          <span class="admin-statusbar__user"><%= currentUser ? currentUser.name : 'Administrador' %></span>
          <a class="btn-link btn-link--small" href="/analytics">Vista analítica</a>
        </div>
      </header>

      <main class="admin-content">
        <section class="admin-kpi-grid" data-reveal>
          <article class="card admin-kpi">
            <span>Activos bajo control</span>
            <strong><%= overview.summary.total_products %></strong>
          </article>
          <article class="card admin-kpi">
            <span>Cuentas operativas</span>
            <strong><%= overview.summary.total_users %></strong>
          </article>
          <article class="card admin-kpi">
            <span>Valor operativo</span>
            <strong>$<%= Number(overview.summary.total_revenue || 0).toLocaleString('es-CO') %></strong>
          </article>
          <article class="card admin-kpi">
            <span>Incidencias activas</span>
            <strong><%= Number(overview.summary.support_rate || 12) %>%</strong>
          </article>
        </section>

        <section class="admin-analytics" data-reveal>
          <article class="card admin-chart">
            <div class="card-copy">
              <h2>Ritmo operativo</h2>
              <p>Evolución de activos y valor ejecutado por mes.</p>
            </div>
            <div class="admin-chart__frame">
              <canvas
                id="admin-growth-chart"
                aria-label="Grafica de crecimiento"
                data-chart='<%- JSON.stringify(overview.revenue || []) %>'
              ></canvas>
            </div>
          </article>
          <article class="card admin-chart">
            <div class="card-copy">
              <h2>Composición de inventario</h2>
              <p>Detalle de categorías, soporte y asignaciones críticas.</p>
            </div>
            <div class="admin-chart__frame">
              <canvas
                id="admin-category-chart"
                aria-label="Grafica por categoria"
                data-chart='<%- JSON.stringify(overview.categoryMix || []) %>'
              ></canvas>
            </div>
          </article>
        </section>

        <section class="card admin-activity" data-reveal>
          <div class="card-copy">
            <h2>Trazabilidad reciente</h2>
            <p>Últimos movimientos del ecosistema Aura.</p>
          </div>
          <div class="table-wrap">
            <table class="apple-clean-table">
              <thead>
                <tr>
                  <th>Accion</th>
                  <th>Area</th>
                  <th>Hora</th>
                </tr>
              </thead>
              <tbody>
                <% activityItems.forEach((item) => { %>
                  <tr>
                    <td class="font-weight-medium"><%= item.actor %> <%= item.action %></td>
                    <td><%= item.area %></td>
                    <td><%= item.when %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </div>
</body>
</html>