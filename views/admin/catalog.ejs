<%- include('../shared/admin-head', { pageTitle: pageTitle, bodyClass: 'admin-catalog' }) %>
<div class="admin-layout">
  <%- include('../shared/admin-sidebar-aurora', { active: 'catalog' }) %>
  <main class="admin-content">
    <header class="admin-topbar admin-reveal" data-reveal>
      <div>
        <p class="admin-breadcrumb">Catálogo Aura</p>
        <h1 class="admin-title">Gestión de inventario y producto destacado</h1>
        <p class="admin-subtitle">Previsualiza el producto estrella, controla escasez y mantiene la ficha técnica lista para vender hardware premium.</p>
      </div>
      <div class="admin-actions">
        <button class="admin-btn admin-btn--ghost" type="button">Actualizar stock</button>
        <button class="admin-btn" type="button">Marcar destacado</button>
      </div>
    </header>

    <section class="admin-preview admin-reveal" data-reveal>
      <article class="admin-product-visual">
        <div class="admin-product-visual__brand">
          <span class="admin-chip">ASUS ROG</span>
          <span class="admin-badge admin-badge--warning"><%= productStar.stockNotice %></span>
        </div>
        <div>
          <p class="admin-label">Producto estrella</p>
          <h2><%= productStar.name %></h2>
          <p class="admin-subtle">Portátil para gaming y creación con alto rendimiento sostenido, ideal para campañas con urgencia y ticket premium.</p>
        </div>
        <div class="admin-price">
          <span class="admin-price__current">$<%= Number(productStar.priceCurrent).toLocaleString('en-US') %> USD</span>
          <span class="admin-price__old">$<%= Number(productStar.priceBefore).toLocaleString('en-US') %> USD</span>
        </div>
        <div class="admin-pill-list">
          <% productStar.badges.forEach((badge) => { %>
            <span class="admin-badge admin-badge--success"><%= badge %></span>
          <% }) %>
        </div>
      </article>

      <article class="admin-card">
        <div class="admin-section-heading">
          <p class="admin-label">Control</p>
          <h2>Alertas y urgencia</h2>
        </div>
        <div class="admin-form-grid">
          <div class="admin-field">
            <label class="admin-form-label" for="stock-alert">Alerta de escasez</label>
            <input id="stock-alert" class="admin-input" type="text" value="Solo quedan 5 unidades disponibles" />
          </div>
          <div class="admin-field">
            <label class="admin-form-label" for="urgency-state">Estado de urgencia</label>
            <select id="urgency-state" class="admin-select">
              <option>Normal</option>
              <option selected>Alta</option>
              <option>Máxima</option>
            </select>
          </div>
          <div class="admin-field">
            <label class="admin-form-label" for="visibility-state">Visibilidad</label>
            <select id="visibility-state" class="admin-select">
              <option selected>Destacado en home</option>
              <option>Solo catálogo</option>
              <option>Oculto</option>
            </select>
          </div>
        </div>
        <div class="admin-control-row">
          <button class="admin-btn" type="button">Guardar control</button>
          <button class="admin-btn admin-btn--ghost" type="button">Programar campaña</button>
        </div>
      </article>
    </section>

    <section class="admin-collection-grid" data-reveal>
      <article class="admin-card admin-collection-card" id="laptops">
        <p class="admin-label">Laptops</p>
        <strong>Movilidad con rendimiento sostenido</strong>
        <p class="admin-subtle">Prioriza equipos listos para trabajo creativo y gaming premium.</p>
      </article>
      <article class="admin-card admin-collection-card" id="smartphones">
        <p class="admin-label">Smartphones</p>
        <strong>Alta rotación y ticket eficiente</strong>
        <p class="admin-subtle">Enfocados en captación, upsell y reposición rápida.</p>
      </article>
      <article class="admin-card admin-collection-card" id="gaming">
        <p class="admin-label">Gaming</p>
        <strong>Productos para performance extrema</strong>
        <p class="admin-subtle">Modelos con urgencia comercial y mensajes de escasez.</p>
      </article>
      <article class="admin-card admin-collection-card" id="accesorios">
        <p class="admin-label">Accesorios</p>
        <strong>Venta cruzada y bundles</strong>
        <p class="admin-subtle">Fundamentales para aumentar el valor del carrito.</p>
      </article>
      <article class="admin-card admin-collection-card" id="smarthome">
        <p class="admin-label">Smart Home</p>
        <strong>Conectividad y automatización</strong>
        <p class="admin-subtle">Línea ideal para expandir el ecosistema Aura.</p>
      </article>
    </section>

    <section class="admin-table-card admin-reveal" data-reveal>
      <div class="admin-section-heading">
        <p class="admin-label">Ficha técnica</p>
        <h2>Datos limpios sin líneas verticales</h2>
      </div>
      <table class="admin-table admin-spec-table">
        <tbody>
          <% productStar.specs.forEach(([label, value]) => { %>
            <tr><td><%= label %></td><td><%= value %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </section>

    <section class="admin-note-card admin-reveal" data-reveal>
      <p class="admin-label">Mensaje de urgencia</p>
      <div class="admin-hero-quote">Activa la escasez: <strong>solo quedan 5 unidades disponibles</strong>. Usa el stock como argumento de decisión, no como bloqueo.</div>
    </section>
  </main>
</div>
</body>
</html>