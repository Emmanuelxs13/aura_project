<%- include('../shared/admin-head', { pageTitle: pageTitle, bodyClass: 'admin-dashboard' }) %>
<div class="admin-layout">
  <%- include('../shared/admin-sidebar-aurora', { active: 'dashboard' }) %>
  <main class="admin-content">
    <header class="admin-topbar admin-reveal" data-reveal>
      <div>
        <p class="admin-breadcrumb">Centro Ejecutivo</p>
        <h1 class="admin-title">Control de acceso y activos</h1>
        <p class="admin-subtitle">Administra métricas, stock, comportamiento y filosofía de marca desde un solo lienzo oscuro y legible.</p>
      </div>
      <div class="admin-actions">
        <a class="admin-btn admin-btn--ghost" href="/admin/catalog">Ir al catálogo</a>
        <a class="admin-btn" href="/admin/marketing">Abrir marketing</a>
      </div>
    </header>

    <section class="admin-kpi-grid" data-reveal>
      <article class="admin-card admin-kpi">
        <p class="admin-kpi__label">CTR tienda</p>
        <p class="admin-kpi__value">4.8%</p>
        <p class="admin-kpi__meta">Rendimiento de captación en campañas activas.</p>
      </article>
      <article class="admin-card admin-kpi">
        <p class="admin-kpi__label">Conversión</p>
        <p class="admin-kpi__value">3.2%</p>
        <p class="admin-kpi__meta">Pedidos confirmados por sesión de compra.</p>
      </article>
      <article class="admin-card admin-kpi">
        <p class="admin-kpi__label">Tiempo en página</p>
        <p class="admin-kpi__value">03:42</p>
        <p class="admin-kpi__meta">Profundidad de lectura y atención sostenida.</p>
      </article>
      <article class="admin-card admin-kpi">
        <p class="admin-kpi__label">Bounce rate</p>
        <p class="admin-kpi__value">28%</p>
        <p class="admin-kpi__meta">Sesiones que requieren ajuste de contenido.</p>
      </article>
    </section>

    <section class="admin-chart-grid" data-reveal>
      <article class="admin-chart-card">
        <div class="admin-section-heading">
          <p class="admin-label">Rendimiento</p>
          <h2>CTR y conversión de la tienda</h2>
        </div>
        <div class="admin-chart">
          <div class="admin-chart-surface">
            <div class="admin-chart-bars">
              <div class="admin-bar"><div class="admin-bar__track"><div class="admin-bar__fill" style="height: 78%;"></div></div><span class="admin-bar__label">CTR</span></div>
              <div class="admin-bar"><div class="admin-bar__track"><div class="admin-bar__fill" style="height: 64%;"></div></div><span class="admin-bar__label">Conv.</span></div>
              <div class="admin-bar"><div class="admin-bar__track"><div class="admin-bar__fill" style="height: 88%;"></div></div><span class="admin-bar__label">Clics</span></div>
              <div class="admin-bar"><div class="admin-bar__track"><div class="admin-bar__fill" style="height: 52%;"></div></div><span class="admin-bar__label">Checkout</span></div>
            </div>
          </div>
        </div>
      </article>

      <article class="admin-chart-card">
        <div class="admin-section-heading">
          <p class="admin-label">Atención</p>
          <h2>Tiempo en página y bounce rate</h2>
        </div>
        <div class="admin-chart">
          <div class="admin-chart-surface">
            <p class="admin-hero-quote">No vendemos solo tecnología. Vendemos velocidad. Creatividad. Rendimiento.</p>
            <div class="admin-pill-list">
              <span class="admin-chip">Tiempo medio 3m 42s</span>
              <span class="admin-chip">Bounce rate 28%</span>
              <span class="admin-chip">Scroll depth 72%</span>
            </div>
          </div>
        </div>
      </article>

      <article class="admin-chart-card">
        <div class="admin-section-heading">
          <p class="admin-label">Embudo</p>
          <h2>Carritos abandonados y scroll depth</h2>
        </div>
        <div class="admin-chart">
          <div class="admin-chart-surface">
            <div class="admin-chart-bars">
              <div class="admin-bar"><div class="admin-bar__track"><div class="admin-bar__fill" style="height: 60%;"></div></div><span class="admin-bar__label">Abandono</span></div>
              <div class="admin-bar"><div class="admin-bar__track"><div class="admin-bar__fill" style="height: 82%;"></div></div><span class="admin-bar__label">Scroll</span></div>
              <div class="admin-bar"><div class="admin-bar__track"><div class="admin-bar__fill" style="height: 46%;"></div></div><span class="admin-bar__label">Recuperación</span></div>
              <div class="admin-bar"><div class="admin-bar__track"><div class="admin-bar__fill" style="height: 74%;"></div></div><span class="admin-bar__label">Retención</span></div>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section class="admin-quote-card admin-reveal" data-reveal>
      <p class="admin-label">Filosofía de marca</p>
      <div class="admin-hero-quote">
        No vendemos solo tecnología. Vendemos velocidad. Creatividad. Rendimiento. Aura existe para que cada decisión se sienta rápida, clara y premium.
      </div>
    </section>
  </main>
</div>
</body>
</html>