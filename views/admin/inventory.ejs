<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="admin-app">
  <% const useAdminLayout = Boolean(isAdmin); %>
  <% if (!useAdminLayout) { %>
    <%- include('../shared/header', { active: 'admin' }) %>
  <% } %>
  <div class="admin-layout">
    <input class="admin-nav-toggle" type="checkbox" id="admin-nav-toggle" aria-label="Abrir menu admin">
    <%- include('../shared/admin-sidebar', { active: 'inventory' }) %>
    <div class="admin-panel">
      <header class="admin-statusbar">
        <label class="admin-toggle" for="admin-nav-toggle" aria-hidden="true">
          <span></span>
          <span></span>
        </label>
        <div>
          <p class="admin-statusbar__eyebrow">Panel Administrativo</p>
          <h1>Control de inventario</h1>
        </div>
        <div class="admin-statusbar__actions">
          <span class="admin-statusbar__user"><%= currentUser ? currentUser.name : 'Administrador' %></span>
          <button class="btn-apple" type="button">Nuevo activo</button>
        </div>
      </header>

      <main class="admin-content">
        <section class="admin-kpi-grid">
          <article class="card admin-kpi">
            <span>Activos totales</span>
            <strong><%= summary.total_products %></strong>
          </article>
          <article class="card admin-kpi">
            <span>Stock global</span>
            <strong><%= summary.total_stock %></strong>
          </article>
          <article class="card admin-kpi">
            <span>Categorias activas</span>
            <strong><%= [...new Set(inventory.map((item) => item.category))].length %></strong>
          </article>
        </section>

        <section class="card admin-activity">
          <div class="card-copy admin-toolbar">
            <div>
              <h2>Inventario operativo</h2>
              <p>CRUD de activos, asignaciones y disponibilidad.</p>
            </div>
            <div class="admin-toolbar__actions">
              <button class="btn-link" type="button">Importar CSV</button>
              <button class="btn-link" type="button">Asignaciones</button>
            </div>
          </div>
          <div class="table-wrap">
            <table class="apple-clean-table">
              <thead>
                <tr>
                  <th>Activo</th>
                  <th>Categoria</th>
                  <th>Stock</th>
                  <th>Estado</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% inventory.forEach((item) => { %>
                  <tr>
                    <td>
                      <div class="admin-user">
                        <span class="font-weight-medium"><%= item.name %></span>
                        <span class="admin-meta">$<%= Number(item.price || 0).toLocaleString('es-CO') %> COP</span>
                      </div>
                    </td>
                    <td><span class="admin-pill"><%= item.category %></span></td>
                    <td class="font-numeric"><%= item.stock %></td>
                    <td>
                      <span class="admin-pill <%= item.stock > 5 ? 'admin-pill--success' : 'admin-pill--warning' %>">
                        <%= item.stock > 5 ? 'Disponible' : 'Critico' %>
                      </span>
                    </td>
                    <td>
                      <div class="admin-table-actions">
                        <button class="btn-link btn-link--small" type="button">Editar</button>
                        <button class="btn-link btn-link--small" type="button">Asignar</button>
                        <button class="btn-link btn-link--small" type="button">Baja</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>

        <section class="card admin-activity">
          <div class="card-copy admin-toolbar">
            <div>
              <h2>Activos (Dispositivos)</h2>
              <p>Lista de dispositivos físicos y su estado.</p>
            </div>
          </div>
          <div class="table-wrap">
            <table class="apple-clean-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Modelo</th>
                  <th>Categoria</th>
                  <th>Serial</th>
                  <th>Estado</th>
                  <th>Precio</th>
                  <th>Creado</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% (devices || []).forEach(function(d){ %>
                  <tr>
                    <td><%= d.id %></td>
                    <td><%= d.model_name %></td>
                    <td><%= d.category %></td>
                    <td><%= d.serial_number || '-' %></td>
                    <td><%= d.status %></td>
                    <td><%= d.purchase_price || '-' %></td>
                    <td><%= new Date(d.created_at).toLocaleDateString() %></td>
                    <td>
                      <a class="btn-link btn-link--small" href="/admin/devices/<%= d.id %>/logs">Incidencias</a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </div>
</body>
</html>
