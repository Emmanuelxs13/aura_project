<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="admin-app">
  <% const adminRoles = ['Admin', 'Administrator']; %>
  <% const useAdminLayout = Boolean(isAdmin); %>
  <% if (!useAdminLayout) { %>
    <%- include('../shared/header', { active: 'admin' }) %>
  <% } %>
  <div class="admin-layout">
    <input class="admin-nav-toggle" type="checkbox" id="admin-nav-toggle" aria-label="Abrir menu admin">
    <%- include('../shared/admin-sidebar', { active: 'users' }) %>
    <div class="admin-panel">
      <header class="admin-statusbar">
        <label class="admin-toggle" for="admin-nav-toggle" aria-hidden="true">
          <span></span>
          <span></span>
        </label>
        <div>
          <p class="admin-statusbar__eyebrow">Panel Administrativo</p>
          <h1>Gestion de usuarios</h1>
        </div>
        <div class="admin-statusbar__actions">
          <span class="admin-statusbar__user"><%= currentUser ? currentUser.name : 'Administrador' %></span>
          <button class="btn-apple" type="button">Nuevo usuario</button>
        </div>
      </header>

      <main class="admin-content">
        <section class="admin-kpi-grid">
          <article class="card admin-kpi">
            <span>Usuarios totales</span>
            <strong><%= summary.total_users %></strong>
          </article>
          <article class="card admin-kpi">
            <span>Admins activos</span>
            <strong><%= users.filter((user) => adminRoles.includes(user.role)).length %></strong>
          </article>
          <article class="card admin-kpi">
            <span>Operadores</span>
            <strong><%= users.filter((user) => user.role === 'Operador').length %></strong>
          </article>
          <article class="card admin-kpi">
            <span>Auditores</span>
            <strong><%= users.filter((user) => user.role === 'Auditor').length %></strong>
          </article>
        </section>

        <section class="card admin-user-form">
          <div class="card-copy">
            <h2>Alta de usuario</h2>
            <p>Crear cuentas nuevas y asignar rol operativo.</p>
          </div>
          <form class="admin-form-grid" method="post" action="/admin/users">
            <label>Nombre
              <input name="name" type="text" placeholder="Nombre completo" required>
            </label>
            <label>Email
              <input name="email" type="email" placeholder="correo@aura.co" required>
            </label>
            <label>Rol
              <select name="role" required>
                <% roleOptions.forEach((role) => { %>
                  <option value="<%= role %>"><%= role %></option>
                <% }) %>
              </select>
            </label>
            <label>Estado
              <select name="status" required>
                <% statusOptions.forEach((status) => { %>
                  <option value="<%= status %>"><%= status %></option>
                <% }) %>
              </select>
            </label>
            <label>Clave temporal
              <input name="password" type="password" minlength="6" required>
            </label>
            <button class="btn-apple" type="submit">Crear usuario</button>
          </form>
        </section>

        <section class="card admin-activity">
          <div class="card-copy admin-toolbar">
            <div>
              <h2>Directorio operativo</h2>
              <p>Administra roles, suspensiones y acceso global.</p>
            </div>
            <div class="admin-toolbar__actions">
              <button class="btn-link" type="button">Exportar</button>
              <button class="btn-link" type="button">Invitar</button>
            </div>
          </div>
          <div class="table-wrap">
            <table class="apple-clean-table">
              <thead>
                <tr>
                  <th>Usuario</th>
                  <th>Rol</th>
                  <th>Estado</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((user) => { %>
                  <tr>
                    <td>
                      <div class="admin-user">
                        <span class="font-weight-medium"><%= user.name %></span>
                        <span class="admin-meta"><%= user.email %></span>
                      </div>
                    </td>
                    <td>
                      <form class="admin-inline-form" method="post" action="/admin/users/<%= user.id %>/role">
                        <select name="role" class="admin-select">
                          <% roleOptions.forEach((role) => { %>
                            <option value="<%= role %>" <%= user.role === role ? 'selected' : '' %>><%= role %></option>
                          <% }) %>
                        </select>
                        <button class="btn-link btn-link--small" type="submit">Guardar</button>
                      </form>
                    </td>
                    <td>
                      <form class="admin-inline-form" method="post" action="/admin/users/<%= user.id %>/status">
                        <select name="status" class="admin-select">
                          <% statusOptions.forEach((status) => { %>
                            <option value="<%= status %>" <%= user.status === status ? 'selected' : '' %>><%= status %></option>
                          <% }) %>
                        </select>
                        <button class="btn-link btn-link--small" type="submit">Actualizar</button>
                      </form>
                    </td>
                    <td>
                      <div class="admin-table-actions">
                        <button class="btn-link btn-link--small" type="button">Ver detalle</button>
                        <button class="btn-link btn-link--small" type="button">Reset clave</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </div>
</body>
</html>
