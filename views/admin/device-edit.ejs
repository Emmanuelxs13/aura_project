<%- include('../shared/header') %>
<div class="admin-layout">
  <%- include('../shared/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-toolbar">
      <h1>Editar Activo</h1>
      <a href="/admin/devices" class="btn-link">Volver a activos</a>
    </div>

    <section class="panel">
      <h2><%= device.model_name %></h2>
      <p class="muted">Asignado a: <%= device.assigned_to || '—' %></p>
      <form method="POST" action="/admin/devices/<%= device.id %>" class="form-grid">
        <label>Modelo<input name="model_name" value="<%= device.model_name %>" required/></label>
        <label>Categoria<input name="category" value="<%= device.category %>"/></label>
        <label>Serial<input name="serial_number" value="<%= device.serial_number %>"/></label>
        <label>Estado<select name="status"><option value="Available" <%= device.status==='Available'?'selected':'' %>>Available</option><option value="Assigned" <%= device.status==='Assigned'?'selected':'' %>>Assigned</option><option value="In Repair" <%= device.status==='In Repair'?'selected':'' %>>In Repair</option><option value="Retired" <%= device.status==='Retired'?'selected':'' %>>Retired</option></select></label>
        <label>Precio<input name="purchase_price" type="number" step="0.01" value="<%= device.purchase_price || '' %>"/></label>
        <label>Fecha compra<input name="purchase_date" type="date" value="<%= device.purchase_date ? device.purchase_date.toISOString().slice(0,10) : '' %>"/></label>
        <label>Especificaciones<textarea name="specifications"><%= device.specifications ? JSON.stringify(device.specifications) : '' %></textarea></label>
        <div></div>
        <button type="submit" class="btn-primary">Guardar cambios</button>
      </form>
    </section>

    <section class="panel">
      <h2>Asignar activo</h2>
      <form method="POST" action="/admin/devices/<%= device.id %>/assign" class="form-grid">
        <label>Asignado a (nombre o usuario)<input name="assignee"/></label>
        <div></div>
        <button class="btn-primary">Asignar</button>
      </form>
    </section>
  </main>
</div>
<%- include('../shared/footer') %>
<script src="/js/admin-ui.js"></script>