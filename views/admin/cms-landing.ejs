<%- include('../shared/admin-head', { pageTitle: pageTitle, bodyClass: 'admin-cms' }) %>
<div class="admin-layout">
  <%- include('../shared/admin-sidebar-aurora', { active: 'cms' }) %>
  <main class="admin-content">
    <header class="admin-topbar admin-reveal" data-reveal>
      <div>
        <p class="admin-breadcrumb">CMS Landing</p>
        <h1 class="admin-title">Gestor de contenido de la tienda</h1>
        <p class="admin-subtitle">Edita el copywriting del home con bloques claros, listos para conversión y consistencia de marca.</p>
      </div>
      <div class="admin-actions">
        <button class="admin-btn admin-btn--ghost" type="button">Vista previa</button>
        <button class="admin-btn" type="button">Publicar cambios</button>
      </div>
    </header>

    <section class="admin-copy-grid" data-reveal>
      <article class="admin-copy-card">
        <div class="admin-section-heading">
          <p class="admin-label">Hero principal</p>
          <h2><%= landingBlocks.hero.title %></h2>
        </div>
        <div class="admin-form-grid">
          <div class="admin-field">
            <label class="admin-form-label">Título</label>
            <input class="admin-input" value="<%= landingBlocks.hero.title %>" />
          </div>
          <div class="admin-field">
            <label class="admin-form-label">Subtítulo</label>
            <textarea class="admin-textarea"><%= landingBlocks.hero.subtitle %></textarea>
          </div>
        </div>
      </article>

      <article class="admin-copy-card">
        <div class="admin-section-heading">
          <p class="admin-label">Barra de beneficios</p>
          <h2>Envíos rápidos, pagos protegidos, garantía oficial</h2>
        </div>
        <div class="admin-form-grid">
          <% landingBlocks.benefits.forEach((benefit, index) => { %>
            <div class="admin-field">
              <label class="admin-form-label">Beneficio <%= index + 1 %></label>
              <input class="admin-input" value="<%= benefit %>" />
            </div>
          <% }) %>
        </div>
      </article>

      <article class="admin-copy-card">
        <div class="admin-section-heading">
          <p class="admin-label">Por qué elegir Aura Store</p>
          <h2>Problema → Solución → Beneficio → Resultado</h2>
        </div>
        <div class="admin-form-grid">
          <div class="admin-field"><label class="admin-form-label">Problema</label><textarea class="admin-textarea"><%= landingBlocks.formula.problem %></textarea></div>
          <div class="admin-field"><label class="admin-form-label">Solución</label><textarea class="admin-textarea"><%= landingBlocks.formula.solution %></textarea></div>
          <div class="admin-field"><label class="admin-form-label">Beneficio</label><textarea class="admin-textarea"><%= landingBlocks.formula.benefit %></textarea></div>
          <div class="admin-field"><label class="admin-form-label">Resultado</label><textarea class="admin-textarea"><%= landingBlocks.formula.result %></textarea></div>
        </div>
      </article>

      <article class="admin-copy-card">
        <div class="admin-section-heading">
          <p class="admin-label">Categorías destacadas</p>
          <h2>Laptops, Smartphones, Gaming, Accesorios, Smart Home</h2>
        </div>
        <div class="admin-pill-list">
          <% landingBlocks.categories.forEach((category) => { %>
            <span class="admin-chip"><%= category %></span>
          <% }) %>
        </div>
      </article>

      <article class="admin-copy-card">
        <div class="admin-section-heading">
          <p class="admin-label">Frases de marca</p>
          <h2>Microcopy de alta conversión</h2>
        </div>
        <div class="admin-form-grid">
          <div class="admin-field"><label class="admin-form-label">Mensaje principal</label><textarea class="admin-textarea"><%= landingBlocks.brand %></textarea></div>
          <div class="admin-field"><label class="admin-form-label">Newsletter</label><textarea class="admin-textarea"><%= landingBlocks.newsletter %></textarea></div>
        </div>
      </article>
    </section>
  </main>
</div>
</body>
</html>