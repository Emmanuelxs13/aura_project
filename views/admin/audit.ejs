<%- include('../shared/header') %>
<div class="admin-layout">
  <%- include('../shared/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-toolbar">
      <h1>Trazabilidad y auditoría</h1>
      <a href="/admin/settings" class="btn-link">Configuración</a>
    </div>

    <section class="panel">
      <h2>Eventos recientes</h2>
      <div style="margin:12px 0 18px; display:flex; gap:8px;">
        <form method="GET" action="/admin/audit" style="flex:1; display:flex; gap:8px;">
          <input name="q" value="<%= q || '' %>" placeholder="Filtrar por actor, acción o recurso" style="flex:1;padding:10px;border:1px solid #e6e6e8;border-radius:8px" />
          <button class="btn-link" type="submit">Buscar</button>
        </form>
        <div>
          <form method="GET" action="/admin/audit">
            <input type="hidden" name="q" value="" />
            <button class="btn-ghost">Limpiar</button>
          </form>
        </div>
      </div>
      <div class="table-wrap">
        <table class="apple-clean-table">
          <thead>
            <tr>
              <th>Cuando</th>
              <th>Actor</th>
              <th>Acción</th>
              <th>Recurso</th>
              <th>Detalles</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(function(l){ %>
              <tr>
                <td><%= new Date(l.created_at).toLocaleString() %></td>
                <td><%= l.actor_name || l.actor_id || 'Sistema' %></td>
                <td><%= l.action %></td>
                <td><%= l.resource %> <%= l.resource_id ? ('#' + l.resource_id) : '' %></td>
                <td><pre class="muted"><%= JSON.stringify(l.details) %></pre></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>
<div style="padding:16px 40px; margin-left:260px">
  <% if (totalPages && totalPages > 1) { %>
    <nav aria-label="Paginacion auditoria">
      <ul style="list-style:none;display:flex;gap:8px;padding:0;margin:0;align-items:center">
        <% if (page > 1) { %>
          <li><a class="btn-link" href="/admin/audit?q=<%= encodeURIComponent(q||'') %>&page=<%= page-1 %>&pageSize=<%= pageSize %>">Anterior</a></li>
        <% } %>
        <% for (let p = 1; p <= totalPages; p++) { %>
          <li><a class="btn-link <%= p===page ? 'is-active' : '' %>" href="/admin/audit?q=<%= encodeURIComponent(q||'') %>&page=<%= p %>&pageSize=<%= pageSize %>"><%= p %></a></li>
        <% } %>
        <% if (page < totalPages) { %>
          <li><a class="btn-link" href="/admin/audit?q=<%= encodeURIComponent(q||'') %>&page=<%= page+1 %>&pageSize=<%= pageSize %>">Siguiente</a></li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</div>
<%- include('../shared/footer') %>
<script src="/js/admin-audit.js"></script>
<script src="/js/admin-ui.js"></script>