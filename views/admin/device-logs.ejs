<%- include('../shared/header') %>
<div class="admin-layout">
  <%- include('../shared/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-toolbar">
      <h1>Incidencias - <%= device.model_name %></h1>
      <a href="/admin/devices" class="btn-link">Volver a activos</a>
    </div>

    <section class="panel">
      <h2>Registrar incidencia</h2>
      <form method="POST" action="/admin/devices/<%= device.id %>/logs" class="form-grid">
        <label>Código<input name="code"/></label>
        <label>Título<input name="title" required/></label>
        <label>Área<input name="area"/></label>
        <label>Costo<input name="maintenance_cost" type="number" step="0.01"/></label>
        <label>Estado<select name="status"><option>Open</option><option>In Progress</option><option>Resolved</option></select></label>
        <label>Notas<textarea name="notes"></textarea></label>
        <div></div>
        <button class="btn-primary">Crear incidencia</button>
      </form>
    </section>

    <section class="panel">
      <h2>Historial de incidencias</h2>
      <div class="table-wrap">
        <table class="apple-clean-table">
          <thead>
            <tr>
              <th>Codigo</th>
              <th>Titulo</th>
              <th>Area</th>
              <th>Costo</th>
              <th>Estado</th>
              <th>Creado</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(function(log){ %>
              <tr>
                <td><%= log.code %></td>
                <td><%= log.title %></td>
                <td><%= log.area %></td>
                <td class="font-numeric"><%= log.maintenance_cost %></td>
                <td><%= log.status %></td>
                <td class="muted"><%= new Date(log.created_at).toLocaleString() %></td>
                <td>
                  <form method="POST" action="/admin/devices/<%= device.id %>/logs/<%= log.id %>/status" style="display:inline-block">
                    <select name="status">
                      <option value="Open" <%= log.status==='Open'?'selected':'' %>>Open</option>
                      <option value="In Progress" <%= log.status==='In Progress'?'selected':'' %>>In Progress</option>
                      <option value="Resolved" <%= log.status==='Resolved'?'selected':'' %>>Resolved</option>
                      <option value="Closed" <%= log.status==='Closed'?'selected':'' %>>Closed</option>
                    </select>
                    <button class="btn-link">Actualizar</button>
                  </form>
                  <form method="POST" action="/admin/devices/<%= device.id %>/logs/<%= log.id %>/delete" style="display:inline-block" data-confirm="Eliminar incidencia?">
                    <button class="btn-ghost">Eliminar</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>
<%- include('../shared/footer') %>
<script src="/js/admin-ui.js"></script>
<script src="/js/admin-support.js"></script>