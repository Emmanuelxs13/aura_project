<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="admin-app">
  <% const useAdminLayout = Boolean(isAdmin); %>
  <% if (!useAdminLayout) { %>
    <%- include('../shared/header', { active: 'admin' }) %>
  <% } %>
  <div class="admin-layout">
    <input class="admin-nav-toggle" type="checkbox" id="admin-nav-toggle" aria-label="Abrir menu admin">
    <%- include('../shared/admin-sidebar', { active: 'settings' }) %>
    <div class="admin-panel">
      <header class="admin-statusbar">
        <label class="admin-toggle" for="admin-nav-toggle" aria-hidden="true">
          <span></span>
          <span></span>
        </label>
        <div>
          <p class="admin-statusbar__eyebrow">Centro Ejecutivo</p>
          <h1>Configuración de plataforma</h1>
        </div>
        <div class="admin-statusbar__actions">
          <span class="admin-statusbar__user"><%= currentUser ? currentUser.name : 'Administrador' %></span>
          <button class="btn-apple" type="button">Guardar cambios</button>
        </div>
      </header>

      <main class="admin-content">
        <section class="admin-analytics" data-reveal>
          <% settings.forEach((setting) => { %>
            <article class="card admin-setting">
              <span class="admin-setting__label"><%= setting.label %></span>
              <strong><%= setting.value %></strong>
              <button class="btn-link btn-link--small" type="button">Editar</button>
            </article>
          <% }) %>
        </section>

        <section class="card admin-activity" data-reveal>
          <div class="card-copy admin-toolbar">
            <div>
              <h2>Auditoría reciente</h2>
              <p>Eventos críticos y cambios en la configuración.</p>
            </div>
            <div class="admin-toolbar__actions">
              <button class="btn-link" type="button">Descargar log</button>
              <button class="btn-link" type="button">Programar backup</button>
            </div>
          </div>
          <div class="table-wrap">
            <table class="apple-clean-table">
              <thead>
                <tr>
                  <th>Evento</th>
                  <th>Responsable</th>
                  <th>Fecha</th>
                </tr>
              </thead>
              <tbody>
                <% audit.forEach((item) => { %>
                  <tr>
                    <td class="font-weight-medium"><%= item.event %></td>
                    <td><%= item.actor %></td>
                    <td><%= item.when %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </div>
</body>
</html>
