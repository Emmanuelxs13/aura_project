<%- include('../shared/header') %>
<div class="admin-layout">
  <%- include('../shared/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-toolbar">
      <h1>Activos</h1>
      <form method="GET" action="/admin/devices" class="inline-form">
        <input type="text" name="q" placeholder="Buscar modelo o serial" />
        <button>Buscar</button>
      </form>
    </div>

    <section class="kpi-grid">
      <div class="kpi">
        <div class="kpi-value"><%= summary.products_count || 0 %></div>
        <div class="kpi-label">Productos</div>
      </div>
      <div class="kpi">
        <div class="kpi-value"><%= devices.length %></div>
        <div class="kpi-label">Activos</div>
      </div>
      <div class="kpi">
        <div class="kpi-value"><%= summary.support_rate || 0 %>%</div>
        <div class="kpi-label">Soporte (%)</div>
      </div>
    </section>

    <section class="panel">
      <h2>Registrar nuevo activo</h2>
      <form method="POST" action="/admin/devices" class="form-grid">
        <label>Modelo<input name="model_name" required/></label>
        <label>Categoria<input name="category"/></label>
        <label>Serial<input name="serial_number"/></label>
        <label>Precio<input name="purchase_price" type="number" step="0.01"/></label>
        <label>Fecha compra<input name="purchase_date" type="date"/></label>
        <label>Especificaciones<textarea name="specifications" placeholder='{"color":"space gray"}'></textarea></label>
        <div></div>
        <button type="submit" class="btn-primary">Crear activo</button>
      </form>
    </section>

    <section class="panel">
      <h2>Listado de activos</h2>
      <table class="table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Modelo</th>
            <th>Categoria</th>
            <th>Serial</th>
            <th>Estado</th>
            <th>Asignado a</th>
            <th>Precio</th>
            <th>Creado</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% devices.forEach(function(device){ %>
            <tr>
              <td><%= device.id %></td>
              <td><%= device.model_name %></td>
              <td><%= device.category %></td>
              <td><%= device.serial_number %></td>
              <td><%= device.status %></td>
              <td><%= device.assigned_to || '-' %></td>
              <td><%= device.purchase_price || '-' %></td>
              <td><%= new Date(device.created_at).toLocaleDateString() %></td>
              <td>
                <a class="btn-link btn-link--small" href="/admin/devices/<%= device.id %>/edit">Editar</a>
                <form method="POST" action="/admin/devices/<%= device.id %>/delete" data-confirm="Eliminar activo?" style="display:inline-block">
                  <button class="btn-ghost">Eliminar</button>
                </form>
                <a class="btn-link" href="/admin/devices/<%= device.id %>/logs">Incidencias</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</div>
<%- include('../shared/footer') %>
<script src="/js/admin-ui.js"></script>