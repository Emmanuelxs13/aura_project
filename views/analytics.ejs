<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/main.css">
  <script defer src="/vendor/chart.umd.min.js"></script>
  <script defer src="/js/charts.js"></script>
</head>
<body class="admin-app">
  <% const useAdminLayout = Boolean(isAdmin); %>
  <% if (!useAdminLayout) { %>
    <%- include('shared/header', { active: 'analytics' }) %>
  <% } %>
  <div class="admin-layout">
    <input class="admin-nav-toggle" type="checkbox" id="admin-nav-toggle" aria-label="Abrir menu admin">
    <%- include('shared/admin-sidebar', { active: 'analytics' }) %>
    <div class="admin-panel">
      <header class="admin-statusbar">
        <label class="admin-toggle" for="admin-nav-toggle" aria-hidden="true">
          <span></span>
          <span></span>
        </label>
        <div>
          <p class="admin-statusbar__eyebrow">Panel Administrativo</p>
          <h1>Analitica avanzada</h1>
        </div>
        <div class="admin-statusbar__actions">
          <span class="admin-statusbar__user"><%= currentUser ? currentUser.name : 'Administrador' %></span>
          <a class="btn-link btn-link--small" href="/admin">Dashboard</a>
        </div>
      </header>

      <main class="admin-content">
        <section class="admin-kpi-grid">
          <article class="card admin-kpi"><span>Productos</span><strong><%= summary.total_products %></strong></article>
          <article class="card admin-kpi"><span>Pedidos</span><strong><%= summary.total_orders %></strong></article>
          <article class="card admin-kpi"><span>Usuarios</span><strong><%= summary.total_users %></strong></article>
          <article class="card admin-kpi"><span>Ingresos</span><strong>$<%= Number(summary.total_revenue || 0).toLocaleString('es-CO') %></strong></article>
        </section>

        <section class="card analytics-chart-card">
          <div class="card-copy">
            <h2>Ingresos por periodo</h2>
            <p>Serie histórica de ventas confirmadas.</p>
          </div>
          <canvas id="valuationChart" data-chart='<%- JSON.stringify(sales) %>'></canvas>
          <canvas id="categoryChart" data-chart='<%- JSON.stringify(categoryMix) %>'></canvas>
        </section>

        <section class="card analytics-table-card">
          <div class="card-copy">
            <h2>Top productos</h2>
            <p>Los productos con mayor ingreso acumulado.</p>
          </div>
          <div class="table-wrap">
            <table class="apple-clean-table">
              <thead>
                <tr>
                  <th>Producto</th>
                  <th>Categoria</th>
                  <th>Unidades</th>
                  <th>Ingresos</th>
                </tr>
              </thead>
              <tbody>
                <% topProducts.forEach((row) => { %>
                  <tr>
                    <td class="font-weight-medium"><%= row.name %></td>
                    <td><%= row.category %></td>
                    <td><%= row.unidades %></td>
                    <td class="font-numeric">$<%= Number(row.ingresos || 0).toLocaleString('es-CO') %> COP</td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </div>
</body>
</html>
