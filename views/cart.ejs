<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include('shared/header', { active: 'cart' }) %>
  <main class="apple-shell">
    <section class="section-heading">
      <p class="eyebrow">Bag</p>
      <h1>Tu carrito y checkout</h1>
      <p class="subtitle">Revisa productos, ajusta cantidades y finaliza la compra con un pedido real en PostgreSQL.</p>
    </section>

    <% if (orderCreated) { %>
      <section class="card success-banner">
        <p class="eyebrow">Pedido confirmado</p>
        <h2>Orden #<%= orderCreated.id %> creada correctamente.</h2>
        <p class="subtitle">El carrito fue vaciado y el pedido quedo registrado para tu usuario.</p>
      </section>
    <% } %>

    <% if (checkoutError) { %>
      <section class="card error-banner">
        <p class="eyebrow">Revisa el checkout</p>
        <h2>No pudimos completar la compra.</h2>
        <p class="subtitle"><%= checkoutError %></p>
      </section>
    <% } %>

    <% if (items.length === 0) { %>
      <section class="card empty-state">
        <h2>Tu carrito esta vacio.</h2>
        <p class="subtitle">Agrega productos desde la tienda para iniciar el checkout.</p>
        <a class="btn-apple" href="/shop">Explorar tienda</a>
      </section>
    <% } else { %>
      <section class="cart-layout">
        <div class="card cart-list-card">
          <% items.forEach((item) => { %>
            <article class="cart-item">
              <div>
                <p class="device-card__meta"><%= item.product.category %></p>
                <h2><a href="/product/<%= item.product.slug %>"><%= item.product.name %></a></h2>
                <p class="subtitle"><%= item.product.tagline %></p>
                <p class="font-numeric">$<%= Number(item.product.price).toLocaleString('es-CO') %> COP</p>
              </div>
              <div class="cart-item__controls">
                <form method="post" action="/cart/items/<%= item.product.id %>" class="cart-qty-form">
                  <label>
                    Cantidad
                    <input type="number" name="quantity" min="1" max="99" value="<%= item.quantity %>">
                  </label>
                  <button class="btn-link" type="submit">Actualizar</button>
                </form>
                <form method="post" action="/cart/items/<%= item.product.id %>/remove">
                  <button class="btn-link btn-link--danger" type="submit">Eliminar</button>
                </form>
              </div>
              <p class="cart-item__total">Subtotal: $<%= Number(item.lineTotal).toLocaleString('es-CO') %> COP</p>
            </article>
          <% }) %>
        </div>

        <aside class="card checkout-card">
          <h2>Resumen</h2>
          <p class="subtitle">Puedes finalizar como invitado. Si ya tienes cuenta, el pedido se asociara automaticamente.</p>
          <div class="summary-row"><span>Unidades</span><strong><%= totals.quantity %></strong></div>
          <div class="summary-row"><span>Total</span><strong>$<%= Number(totals.amount).toLocaleString('es-CO') %> COP</strong></div>
          <form method="post" action="/checkout" class="checkout-form">
            <label>
              Nombre de envio
              <input type="text" name="shippingName" value="<%= currentUser ? currentUser.name : '' %>" placeholder="Nombre completo">
            </label>
            <label>
              Correo de envio
              <input type="email" name="shippingEmail" value="<%= currentUser ? currentUser.email : '' %>" placeholder="correo@ejemplo.com">
            </label>
            <label>
              Direccion
              <textarea name="shippingAddress" rows="4" placeholder="Direccion de entrega o retiro en tienda"></textarea>
            </label>
            <button class="btn-apple" type="submit">Finalizar compra</button>
          </form>
        </aside>
      </section>
    <% } %>
  </main>
  <%- include('shared/footer') %>
</body>
</html>